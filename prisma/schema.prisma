datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Goal {
  id                  String   @id @default(uuid())
  name                String
  nameNormalized      String   @unique
  targetAmount        Float
  currentAmount       Float
  monthlyContribution Float
  expectedReturn      Float
  targetDate          DateTime
  priority            String
  status              String
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  contributions       Contribution[]

  @@index([status])
  @@index([priority])
  @@index([targetDate])
}

model Contribution {
  id               String   @id @default(uuid())
  goalId           String
  amount           Float
  contributionDate DateTime
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  goal             Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([contributionDate])
}

model ScenarioTemplate {
  id           String   @id @default(uuid())
  name         String   @unique
  annualReturn Float
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
